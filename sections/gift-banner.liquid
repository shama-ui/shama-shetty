<section class="gift-banner">

  <!-- First Row: Content -->
  <div class="gift-banner__intro page-width">
    <div class="hamburger-image">
        <button class="hamburger-toggle" type="button" aria-label="Toggle menu">
            <img
            class="menu-icon"
            src="{{ 'hamburger-menu.svg' | asset_url }}"
            data-menu="{{ 'hamburger-menu.svg' | asset_url }}"
            data-close="{{ 'tisso-popup-close.svg' | asset_url }}"
            alt="Menu"
            width="18"
            height="18"
            >
        </button>
    </div>
    
    <h1>{{ section.settings.heading }}</h1>

    <p>{{ section.settings.description }}</p>

    <a href="{{ section.settings.button_link }}" class="gift-banner__button">
      {{ section.settings.button_text }}
      <span>→</span>
    </a>
  </div>

  <div class="mobile-menu">
    <p>{{ section.settings.description }}</p>

    <a href="{{ section.settings.button_link }}" class="gift-banner__button">
      {{ section.settings.button_text }}
      <span>→</span>
    </a>
  </div>

  <div class="gift-banner__full-image">
  <img
    src="{{ 'banner-image1.svg' | asset_url }}"
    alt="{{ section.settings.heading }}"
    loading="lazy"
    width="2000"
    height="auto"
  >
  </div>


  <!-- Third Row: Two Column -->
  <div class="gift-banner__two-column page-width">

    <div class="gift-banner__content">

      <h2>{{ section.settings.second_heading }}</h2>

      <p>{{ section.settings.second_description }}</p>

      <a href="{{ section.settings.second_button_link }}" class="gift-banner__button_two">
        {{ section.settings.second_button_text }}
        <span>→</span>
      </a>

    </div>

    <div class="gift-banner__image">

        <img
            src="{{ 'banner-image-two.svg' | asset_url }}"
            alt="{{ section.settings.second_heading }}"
            class="desktop-image"
            loading="lazy"
            width="1200"
            height="800"
        >
        <img
            src="{{ 'mobile-banner-image.svg' | asset_url }}"
            alt="{{ section.settings.second_heading }}"
            class="mobile-image"
            loading="lazy"
            width="1200"
            height="800"
        >
        
        <a href="{{ section.settings.second_button_link }}" class="gift-banner__button_two">
        {{ section.settings.second_button_text }}
        <span>→</span>
        </a>

    </div>

  </div>


  <!-- Last Row Center Text -->
  <div class="gift-banner__footer-text">
    {{ section.settings.footer_text }}
  </div>


</section>


<style>

.gift-banner{
  width:100%;
}


.page-width{
  {% comment %} max-width:1200px; {% endcomment %}
  margin:0 auto;
  padding:0 0 0 40px;
}


/* First Section */

.gift-banner__intro{
  text-align:left;
  padding: 10px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #F5F5F5;
}

.gift-banner__intro .hamburger-image{
    display:none;
}


.gift-banner__intro h1{
  font-size:32px;
  font-weight: 600;
  margin:0;
}


.gift-banner__intro p{
  font-size:16px;
  font-weight:400;
  max-width:500px;
  line-height:1.6;
  margin:0;
}


.gift-banner__button{
  position: relative;
  display: inline-flex;
  font-size: 16px;
  align-items: center;
  gap: 10px;
  padding: 12px;
  line-height: 20px;
  background: #FFF544;
  color: #000;
  text-decoration: none;
  font-weight: 400;
  overflow: hidden;
  z-index: 1;
  transition: color 0.3s ease;
}

.gift-banner__button::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 0;
  height: 100%;
  background: #000; 
  transition: width 0.4s ease;
  z-index: -1;
}

.gift-banner__button:hover::before {
  width: 100%;
}

.gift-banner__button:hover {
  color: #fff;
}


/* Full Image */

.gift-banner__full-image img{
  width:100%;
  display:block;
}


/* Two Column */

.gift-banner__two-column{
  display:grid;
  grid-template-columns:1fr 1.9fr;
  align-items:center;
  gap:20px;
}

.gift-banner__image a{
    display:none;
}

.gift-banner__image img{
  width:100%;
}

.gift-banner__image .desktop-image{
    display:block;
}

.gift-banner__image .mobile-image{
    display:none;
}


.gift-banner__content h2{
  font-size:70px;
  font-weight: 500;
}

.gift-banner__content p{
  font-family: "Jost", sans-serif;
  font-size:18px;
  font-weight:400;
}

.gift-banner__button_two{
  position: relative;
  display: inline-flex;
  align-items: center;
  font-family: "Jost", sans-serif;
  font-size:16px;
  font-weight: 400;
  gap: 10px;
  padding: 14px 28px;
  margin-top: 30px;
  background: #000;
  color: #fff;
  text-decoration: none;
  overflow: hidden;
  z-index: 1;
  transition: color 0.3s ease;
}

.gift-banner__button_two::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 0;
  height: 100%;
  background: #FFF544; /* Yellow */
  transition: width 0.4s ease;
  z-index: -1;
}

.gift-banner__button_two:hover::before {
  width: 100%;
}

.gift-banner__button_two:hover {
  color: #000;
}

/* Footer */

.gift-banner__footer-text{
  text-align:center;
  padding:10px 40px;
  font-size:14px;
  background-color:#F5F5F5;
}

/* Tablet */

@media(max-width:1024px){
  .hamburger-toggle{
    border:0;
    background:none;
    padding:0;
    cursor:pointer;
  }

  .menu-icon{
    width:18px;
    height:18px;
  }

  .mobile-menu{
    display:none;
    background: #F2F2F2;
    padding:20px;
    text-align: center;
  }

  .mobile-menu p{
    font-family: "Jost", sans-serif;
    font-size:16px;
    font-weight: 400;
    color:#000000;
  }

  .mobile-menu.active{
    display:block;
    position:absolute;
    width:100%
  }

  .gift-banner__full-image{
    display:none;
  }

  .gift-banner__two-column{
    grid-template-columns:1fr;
    padding:0;
  }

  .gift-banner__image{
    position: relative;
  }

  .gift-banner__image .desktop-image{
    display:none;
  }

  .gift-banner__image .mobile-image{
    display:block;
  }

  .gift-banner__image a{
    display:block;
    position:absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom:15%;
    min-width:200px;
    text-align:center
  }

  .gift-banner__intro{
    justify-content: center;
    position:relative;
    box-shadow: 0px 2px 4px 0px #00000026;
    background-color:#F7F7F7;
  }

  .gift-banner__intro .hamburger-image{
    display:block;
    height:12px;
    width:18px;
    position:absolute;
    left:16px
  }

  .gift-banner__intro h1{
    font-size:36px;
  }

  .gift-banner__intro p, .gift-banner__intro a{
    display:none;
  }
  
  .gift-banner__content{
    margin-top:49px;
    text-align: center;
  }

  .gift-banner__content h2{
    margin-bottom:24px;
  }

  .gift-banner__content p{
    margin: 0 18px 0 16px
  }

  .gift-banner__content .gift-banner__button_two{
    display:none;
  }

}


/* Mobile */

@media(max-width:600px){

  .gift-banner__intro{
    padding:40px 20px;
  }


  .gift-banner__intro h1{
    font-size:30px;
  }


  .gift-banner__content h2{
    font-size:28px;
  }

}

</style>

<script>
document.addEventListener("DOMContentLoaded", function(){

  const hamburger = document.querySelector(".hamburger-toggle");
  const icon = document.querySelector(".menu-icon");
  const menu = document.querySelector(".mobile-menu");

  if(hamburger){

    hamburger.addEventListener("click", function(){

      menu.classList.toggle("active");

      if(menu.classList.contains("active")){

        icon.src = icon.dataset.close;

      }else{

        icon.src = icon.dataset.menu;

      }

    });

  }

});
</script>


{% schema %}
{
  "name": "Gift Banner",
  "settings": [

    {
      "type":"text",
      "id":"heading",
      "label":"Main Heading",
      "default":"Tisso Vison"
    },

    {
      "type":"textarea",
      "id":"description",
      "label":"Description",
      "default":"Find the ideal gift for your loved ones"
    },

    {
      "type":"text",
      "id":"button_text",
      "label":"Button Text",
      "default":"CHOOSE GIFT"
    },

    {
      "type":"url",
      "id":"button_link",
      "label":"Button Link"
    },


    {
      "type":"text",
      "id":"second_heading",
      "label":"Second Heading",
      "default":"The Gift Guide"
    },

    {
      "type":"textarea",
      "id":"second_description",
      "label":"Second Description",
      "default":"Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },

    {
      "type":"text",
      "id":"second_button_text",
      "label":"Second Button Text",
      "default":"SHOP NOW"
    },

    {
      "type":"url",
      "id":"second_button_link",
      "label":"Second Button Link"
    },

    {
      "type":"text",
      "id":"footer_text",
      "label":"Bottom Center Text",
      "default":"SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    }

  ],


  "presets":[
    {
      "name":"Gift Banner"
    }
  ]

}
{% endschema %}