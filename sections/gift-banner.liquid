<section class="gift-banner">

  <!-- First Row: Content -->
  <div class="gift-banner__intro page-width">
    <h1>{{ section.settings.heading }}</h1>

    <p>{{ section.settings.description }}</p>

    <a href="{{ section.settings.button_link }}" class="gift-banner__button">
      {{ section.settings.button_text }}
      <span>→</span>
    </a>
  </div>

  <div class="gift-banner__full-image">
  <img
    src="{{ 'banner-image1.svg' | asset_url }}"
    alt="{{ section.settings.heading }}"
    loading="lazy"
    width="2000"
    height="auto"
  >
  </div>


  <!-- Third Row: Two Column -->
  <div class="gift-banner__two-column page-width">

    <div class="gift-banner__content">

      <h2>{{ section.settings.second_heading }}</h2>

      <p>{{ section.settings.second_description }}</p>

      <a href="{{ section.settings.second_button_link }}" class="gift-banner__button_two">
        {{ section.settings.second_button_text }}
        <span>→</span>
      </a>

    </div>

    <div class="gift-banner__image">

    <img
        src="{{ 'banner-image-two.svg' | asset_url }}"
        alt="{{ section.settings.second_heading }}"
        loading="lazy"
        width="1200"
        height="800"
    >

    </div>

  </div>


  <!-- Last Row Center Text -->
  <div class="gift-banner__footer-text">
    {{ section.settings.footer_text }}
  </div>


</section>


<style>

.gift-banner{
  width:100%;
}


.page-width{
  max-width:1200px;
  margin:0 auto;
  padding:0 20px;
}


/* First Section */

.gift-banner__intro{
  text-align:left;
  padding: 16px 8px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #F5F5F5;
}


.gift-banner__intro h1{
  font-size:48px;
  margin:0;
}


.gift-banner__intro p{
  {% comment %} font-family:Jost; {% endcomment %}
  font-size:16px;
  font-weight:400;
  max-width:500px;
  line-height:1.6;
  margin:0;
}


.gift-banner__button{
  position: relative;
  display: inline-flex;
  font-size: 16px;
  align-items: center;
  gap: 10px;
  padding: 12px;
  background: #f4c542;
  color: #000;
  text-decoration: none;
  font-weight: 400;
  overflow: hidden;
  z-index: 1;
  transition: color 0.3s ease;
}

.gift-banner__button::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 0;
  height: 100%;
  background: #000; 
  transition: width 0.4s ease;
  z-index: -1;
}

.gift-banner__button:hover::before {
  width: 100%;
}

.gift-banner__button:hover {
  color: #fff;
}


/* Full Image */

.gift-banner__full-image img{
  width:100%;
  display:block;
}


/* Two Column */

.gift-banner__two-column{
  display:grid;
  grid-template-columns:1fr 1fr;
  align-items:center;
  gap:40px;
}


.gift-banner__image img{
  width:100%;
  display:block;
}


.gift-banner__content h2{
  font-size:36px;
}

.gift-banner__content p{
  {% comment %} font-family:Jost; {% endcomment %}
  font-size:20px;
  font-weight:400;
}

.gift-banner__button_two{
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 14px 28px;
  background: #000;
  color: #fff;
  text-decoration: none;
  font-weight: 600;
  overflow: hidden;
  z-index: 1;
  transition: color 0.3s ease;
}

.gift-banner__button_two::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 0;
  height: 100%;
  background: #f4c542; /* Yellow */
  transition: width 0.4s ease;
  z-index: -1;
}

.gift-banner__button_two:hover::before {
  width: 100%;
}

.gift-banner__button_two:hover {
  color: #000;
}

/* Footer */

.gift-banner__footer-text{
  text-align:center;
  padding:30px;
  font-size:14px;
}

/* Tablet */

@media(max-width:900px){

  .gift-banner__two-column{
    grid-template-columns:1fr;
  }


  .gift-banner__intro h1{
    font-size:36px;
  }

}


/* Mobile */

@media(max-width:600px){

  .gift-banner__intro{
    padding:40px 20px;
  }


  .gift-banner__intro h1{
    font-size:30px;
  }


  .gift-banner__content h2{
    font-size:28px;
  }

}

</style>


{% schema %}
{
  "name": "Gift Banner",
  "settings": [

    {
      "type":"text",
      "id":"heading",
      "label":"Main Heading",
      "default":"Tisso Vison"
    },

    {
      "type":"textarea",
      "id":"description",
      "label":"Description",
      "default":"Find the ideal gift for your loved ones"
    },

    {
      "type":"text",
      "id":"button_text",
      "label":"Button Text",
      "default":"CHOOSE GIFT"
    },

    {
      "type":"url",
      "id":"button_link",
      "label":"Button Link"
    },


    {
      "type":"text",
      "id":"second_heading",
      "label":"Second Heading",
      "default":"The Gift Guide"
    },

    {
      "type":"textarea",
      "id":"second_description",
      "label":"Second Description",
      "default":"Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },

    {
      "type":"text",
      "id":"second_button_text",
      "label":"Second Button Text",
      "default":"SHOP NOW"
    },

    {
      "type":"url",
      "id":"second_button_link",
      "label":"Second Button Link"
    },

    {
      "type":"text",
      "id":"footer_text",
      "label":"Bottom Center Text",
      "default":"SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    }

  ],


  "presets":[
    {
      "name":"Gift Banner"
    }
  ]

}
{% endschema %}