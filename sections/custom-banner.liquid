<section class="custom-banner">

  <div class="banner-content">

    <h1>
      {{ section.settings.heading }}
    </h1>

    <p>
      {{ section.settings.description }}
    </p>

    <a 
      href="{{ section.settings.button_link }}"
      class="banner-button"
    >
      {{ section.settings.button_text }}
    </a>

  </div>

</section>


<style>

.banner-content{
    display: grid;
}

.custom-banner {
  padding: 80px 20px;
  text-align: center;
  background: #f5f5f5;
}


.banner-button {
  display:inline-block;
  padding:15px 35px;
  background:black;
  color:white;
  text-decoration:none;
  transition:0.3s;
}


.banner-button:hover {
  transform:scale(1.1);
}


</style>


{% schema %}
{
  "name": "Custom Banner",

  "settings": [

    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome"
    },

    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Banner description"
    },

    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },

    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }

  ],

  "presets": [
    {
      "name": "Custom Banner"
    }
  ]

}
{% endschema %}