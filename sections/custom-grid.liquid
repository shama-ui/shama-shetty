<section class="tissot-section">

  <div class="tissot-container">

    <!-- Header -->
    <div class="tissot-header">
      <h1>{{ section.settings.heading }}</h1>
    </div>


    <!-- Image Grid -->
    <div class="tissot-grid">

      {% for block in section.blocks %}

        <div class="tissot-item">

          {% if block.settings.image != blank %}

            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              loading="lazy"
              alt="{{ block.settings.product.title }}"
            >

          {% endif %}


          <!-- Plus Button -->

          {% assign product = block.settings.product %}

          {% if product != blank %}

          <button 
            class="product-hotspot"
            data-title="{{ product.title }}"
            data-image="{{ product.featured_image | image_url: width:500 }}"
            data-price="{{ product.price | money }}"
            data-description="{{ product.description | strip_html }}"
          >
            +
          </button>

          {% endif %}


        </div>


      {% endfor %}

    </div>


  </div>

</section>



<!-- Product Popup -->

<div class="product-modal">

  <div class="modal-content">

    <button class="modal-close">
      ×
    </button>


    <img class="modal-image">


    <div class="modal-details">

      <h2 class="modal-title"></h2>

      <p class="modal-price"></p>

      <p class="modal-description"></p>

      <a href="#" class="modal-button">
        View Product
      </a>

    </div>


  </div>

</div>



<script src="{{ 'tissot-popup.js' | asset_url }}" defer></script>

<style>
    .tissot-container{
  padding:40px;
}


.tissot-header h1{
  font-size:42px;
  margin-bottom:40px;
}


.tissot-grid{

  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:24px;

}


.tissot-item{

  position:relative;

}


.tissot-item img{

  width:100%;
  height:100%;
  object-fit:cover;

}



.product-hotspot{

 position:absolute;

 right:50%;
 top:50%;

 transform:translate(50%,-50%);

 width:32px;
 height:32px;

 border-radius:50%;
 border:none;

 background:white;

 font-size:22px;

 cursor:pointer;

}



.product-modal{

 display:none;

 position:fixed;

 inset:0;

 background:rgba(0,0,0,.6);

 justify-content:center;

 align-items:center;

 z-index:9999;

}



.product-modal.active{

 display:flex;

}



.modal-content{

 background:white;

 width:600px;

 padding:30px;

 display:flex;

 gap:30px;

 position:relative;

}


.modal-image{

 width:250px;

 height:250px;

 object-fit:cover;

}


.modal-close{

 position:absolute;

 right:15px;

 top:10px;

 border:none;

 background:none;

 font-size:30px;

 cursor:pointer;

}


.modal-title{

 font-size:24px;

}


.modal-button{

 display:inline-block;

 margin-top:20px;

 padding:12px 25px;

 background:black;

 color:white;

 text-decoration:none;

}



@media(max-width:768px){

.tissot-grid{

grid-template-columns:repeat(2,1fr);

}


.modal-content{

flex-direction:column;

width:90%;

}


}
</style>



{% schema %}
{
  "name": "Tissot Vision Wild",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tissot vision in the wild"
    }
  ],

  "blocks": [
    {
      "type": "product_image",
      "name": "Product Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],


  "presets": [
    {
      "name": "Tissot Vision Wild"
    }
  ]
}
{% endschema %}