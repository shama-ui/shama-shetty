<section class="vision-grid">
  <div class="page-width">
    <h2>{{ section.settings.heading }}</h2>

    <div class="vision-grid-wrapper">
      {% for block in section.blocks %}
        <div class="vision-item">

          <div class="vision-image">

            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 800
                | image_tag:
                  loading: 'lazy',
                  widths: '400,600,800',
                  width: 800,
                  height: 800,
                  alt: block.settings.title
              }}
            {% endif %}

            <button
              class="vision-plus"
              data-popup="popup-{{ block.id }}"
              type="button">
              +
            </button>

          </div>

          <!-- Popup -->
          <div class="vision-popup" id="popup-{{ block.id }}">
            <div class="vision-popup-content">

              <button class="popup-close">&times;</button>

              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    width: 1200,
                    height: 1200,
                    alt: block.settings.title
                }}
              {% endif %}

              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.description }}</p>

            </div>
          </div>

        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>

.vision-grid-wrapper {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

@media (max-width: 990px) {
  .vision-grid-wrapper {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 767px) {
  .vision-grid-wrapper {
    grid-template-columns: 1fr;
  }
}

.vision-image {
  position: relative;
  overflow: hidden;
}

.vision-image img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

/* + icon */
.vision-plus {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 42px;
  height: 42px;
  border-radius: 50%;
  border: none;
  background: #fff;
  color: #000;
  font-size: 28px;
  cursor: pointer;
  z-index: 2;
  transition: .3s;
}

.vision-plus:hover {
  background: #f4c542;
}

/* Popup */

.vision-popup {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.7);
  z-index: 999;
  justify-content: center;
  align-items: center;
}

.vision-popup.active {
  display: flex;
}

.vision-popup-content {
  background: #fff;
  width: 90%;
  max-width: 700px;
  padding: 30px;
  position: relative;
  border-radius: 10px;
}

.vision-popup-content img {
  width: 100%;
  margin-bottom: 20px;
}

.popup-close {
  position: absolute;
  top: 10px;
  right: 15px;
  border: none;
  background: none;
  font-size: 30px;
  cursor: pointer;
}

</style>

{% schema %}
{
  "name": "Custom Image Grid",

  "settings": [

    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    },

    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    }

  ],

  "presets": [
    {
      "name": "Custom Image Grid"
    }
  ]
}
{% endschema %}