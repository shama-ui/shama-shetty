<section class="tissot-section">

  <div class="tissot-container">

    <!-- Header -->
    <div class="tissot-header">
      <h1>{{ section.settings.heading }}</h1>
    </div>


    <!-- Image Grid -->
    <div class="tissot-grid">

      {% for block in section.blocks %}

        <div class="tissot-item">

          {% if block.settings.image != blank %}

            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              loading="lazy"
              alt="{{ block.settings.product.title }}"
            >

          {% endif %}


          <!-- Plus Button -->

          {% assign product = block.settings.product %}

          {% if product != blank %}

          <button 
            class="product-hotspot"
            data-title="{{ product.title }}"
            data-image="{{ product.featured_image | image_url: width:500 }}"
            data-price="{{ product.price | money }}"
            data-description="{{ product.description | strip_html }}"
          >
            +
          </button>

          {% endif %}


        </div>


      {% endfor %}

    </div>


  </div>

</section>



<!-- Product Popup -->

<div class="product-modal">

  <div class="modal-content">

    <button class="modal-close">
      ×
    </button>


    <img class="modal-image">


    <div class="modal-details">

      <h2 class="modal-title"></h2>

      <p class="modal-price"></p>

      <p class="modal-description"></p>

      <a href="#" class="modal-button">
        View Product
      </a>

    </div>


  </div>

</div>



<script src="{{ 'tissot-popup.js' | asset_url }}" defer></script>



{% schema %}
{
  "name": "Tissot Vision Wild",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tissot vision in the wild"
    }
  ],

  "blocks": [
    {
      "type": "product_image",
      "name": "Product Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],


  "presets": [
    {
      "name": "Tissot Vision Wild"
    }
  ]
}
{% endschema %}