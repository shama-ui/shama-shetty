<section class="custom-grid-section">

  <div class="custom-grid-container">

    <!-- Title -->
    <div class="custom-grid-title">
      <h2>{{ section.settings.heading }}</h2>
    </div>


    <!-- Images Grid -->
    <div class="custom-grid-images">

      {% assign selected_collection = section.settings.collection %}

      {% if selected_collection != blank %}

        {% for product in selected_collection.products %}

          <div class="custom-grid-item">

            {% if product.featured_image %}
              <img
            src="{{ product.featured_image | image_url: width: 600 }}"
            alt="{{ product.title | escape }}"
            width="{{ product.featured_image.width }}"
            height="{{ product.featured_image.height }}"
            loading="lazy"
            >
            {% endif %}

          </div>

        {% endfor %}

      {% endif %}

    </div>

  </div>

</section>


<style>

.custom-grid-section {
  padding: 60px 40px;
}


.custom-grid-container {
  display: flex;
  flex-direction: column;
  gap: 40px;
}


/* Left Title */

.custom-grid-title {
  width: 100%;
}


.custom-grid-title h2 {
  font-size: 40px;
  font-weight: 700;
  margin: 0;
}


/* Image Grid */

.custom-grid-images {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(4, 1fr); /* Laptop - 4 columns */
  gap: 24px;
}


.custom-grid-item img {
  width: 100%;
  height: auto;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  display: block;
  transition: transform .3s ease;
}


.custom-grid-item img:hover {
  transform: scale(1.05);
}


/* Tablet - 3 columns */

@media (max-width: 1024px) {

  .custom-grid-images {
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

}


/* Mobile - 2 columns */

@media (max-width: 768px) {

  .custom-grid-images {
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
  }

}


/* Small mobile - 1 column */

@media (max-width: 480px) {

  .custom-grid-images {
    grid-template-columns: repeat(1, 1fr);
  }

}

</style>


{% schema %}
{
  "name": "Custom Image Grid",

  "settings": [

    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    },

    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    }

  ],

  "presets": [
    {
      "name": "Custom Image Grid"
    }
  ]
}
{% endschema %}