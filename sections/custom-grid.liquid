<section class="custom-grid page-width">

  {% if section.settings.title != blank %}
    <h2 class="custom-grid__title">
      {{ section.settings.title }}
    </h2>
  {% endif %}

  <div class="custom-grid__wrapper">

    {% assign collection = section.settings.collection %}

    {% if collection != blank %}

      {% for product in collection.products %}

        <div class="custom-grid__item">

          {% if product.featured_image %}
            <img
              src="{{ product.featured_image | image_url: width: 800 }}"
              alt="{{ product.title | escape }}"
              loading="lazy"
              width="400"
              height="400"
            >
          {% endif %}

        </div>

      {% endfor %}

    {% else %}

      <p>Please select a collection from the Theme Customizer.</p>

    {% endif %}

  </div>

</section>

<style>

.custom-grid{
  padding:60px 0;
}

.custom-grid__title{
  text-align:center;
  font-size:36px;
  font-weight:700;
  margin-bottom:40px;
}

.custom-grid__wrapper{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:20px;
}

.custom-grid__item img{
  width:100%;
  height:350px;
  object-fit:cover;
  display:block;
  border-radius:10px;
}

@media(max-width:990px){

.custom-grid__wrapper{
grid-template-columns:repeat(2,1fr);
}

}

@media(max-width:749px){

.custom-grid__wrapper{
grid-template-columns:1fr;
}

.custom-grid__title{
font-size:28px;
}

}

</style>

{% schema %}
{
  "name": "Custom Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Our Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    }
  ],
  "presets": [
    {
      "name": "Custom Grid"
    }
  ]
}
{% endschema %}