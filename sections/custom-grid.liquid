<section class="tisso-vision-section">
    <div class="tisso-container">

        <div class="tisso-header">
            <h2>{{ section.settings.heading }}</h2>
        </div>

        <!-- Grid section -->

        <div class="tisso-grid">
            {% assign collection = collections[section.settings.collection] %}
            {% if collection != blank %}
                {% for product in collection.products %}
                    <div class="tisso-card">
                        <div class="tisso-image-wrapper">
                            <img src="{{ product.featured_image | image_url: width:800 }}" 
                                width="{{ product.featured_image.width }}"
                                height="{{ product.featured_image.height }}"
                                loading="lazy"
                                alt="{{  product.title }}">
                            
                            <button class="tisso-plus" type="button" data-product-id="product-{{ product.id }}">+</button>
                        </div>
                        <div id="product-{{ product.id }}" class="tisso-product-data" hidden>
                            <div class="product-info">
                                <div class="product-img-wrapper">
                                    <img src="{{ product.featured_image | image_url: width:500 }}" 
                                    width="500"
                                    height="500"
                                    alt="{{  product.title }}">
                                </div>
                                <div class="product-description"> 
                                    <h3>{{ product.title }}</h3>
                                    <div class="price">
                                    {{ product.price | money }}
                                    </div>

                                    <div>
                                    {{ product.description | strip_html | truncate:150 }}
                                    </div>
                                </div>
                            </div>

                            <!-- Product Options -->

                            <div class="product-options">

                                {% for option in product.options_with_values %}

                                {% if option.name == 'Color' %}

                                    <div class="option-title">
                                    Color
                                    </div>

                                    <div class="color-options">

                                    {% for value in option.values %}

                                        <button 
                                        class="color-item"
                                        data-color="{{ value }}"
                                        style="border-left-color: {{ value | downcase }};"
                                        >
                                        {{ value }}
                                        </button>

                                    {% endfor %}

                                    </div>


                                {% elsif option.name == 'Size' %}

                                    <div class="option-title">
                                    Size
                                    </div>

                                    <select class="size-select">

                                    <option>
                                        Choose your size
                                    </option>

                                    {% for value in option.values %}

                                        <option value="{{ value }}">
                                        {{ value }}
                                        </option>

                                    {% endfor %}

                                    </select>


                                {% endif %}

                                {% endfor %}

                            </div>

                            <a href="{{ product.url }}" class="view-product">
                            ADD TO CART
                            <span>→</span>
                            </a>

                        </div>
                    </div>

                    <!-- Hidden Product Data -->

                    <div 
                        class="tisso-product-data"
                        id="product-{{ product.id }}"
                        hidden
                    >

                        <div class="product-image">
                        <img
                            src="{{ product.featured_image | image_url: width:500 }}"
                            width="500"
                            height="500"
                            alt="{{ product.title }}"
                        >
                        </div>


                        <h3>
                        {{ product.title }}
                        </h3>


                        <div class="price">
                        {{ product.price | money }}
                        </div>


                        <div class="description">
                        {{ product.description | strip_html | truncate: 150 }}
                        </div>


                        <a 
                        href="{{ product.url }}"
                        class="view-product"
                        >
                        View Product
                        </a>


                    </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</section>

<!-- Popup -->

<div class="tisso-modal">
  <div class="tisso-overlay"></div>
  <div class="tisso-popup">
    <button class="tisso-close">
      <img
        src="{{ 'tisso-popup-close.svg' | asset_url }}"
        alt="close"
        loading="lazy"
        width="2000"
        height="auto"
        >
    </button>
    <div class="tisso-popup-content"></div>
  </div>
</div>

<style>

.tisso-container{
    width:100%;
    padding:40px 20px;
}

.tisso-header h2{
    margin:0 0 30px;
    font-size:42px;
    font-weight:400;
}

.tisso-grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:25px;
}

.tisso-card{
    position:relative;
}

.tisso-image-wrapper{
    position:relative;
    overflow:hidden;
}

.tisso-image-wrapper img{
    width:100%;
    height:100%;
    object-fit:cover;
    display:block;
}

.tisso-plus{
    position:absolute;
    right:15px;
    bottom:15px;
    width:40px;
    height:40px;
    border-radius:50%;
    border:none;
    background:white;
    font-size:28px;
    cursor:pointer;
    display:flex;
    align-items:center;
    justify-content:center;
    box-shadow:0 2px 8px rgba(0,0,0,.2);
    transition:.3s;
}

.tisso-plus:hover{
    transform:scale(1.1);
}

/* Modal */

.tisso-modal{
    display:none;
    position:fixed;
    inset:0;
    z-index:9999;
}

.tisso-modal.active{
    display:block;
}

.tisso-overlay{
    position:absolute;
    inset:0;
    background:rgba(0,0,0,.5);
}

.tisso-close img{
  pointer-events: none;
}

.tisso-popup{
    position:relative;
    background:#fff;
    width:355px;
    max-width:700px;
    padding:40px 16px 30px;
    top:50%;
    left:50%;
    transform:translate(-50%,-50%);
    z-index:2;
    box-shadow: 0px 2px 4px 0px #00000033;
}

.tisso-close{
    position:absolute;
    right:15px;
    top:15px;
    padding: 0;
    border:none;
    background:none;
    font-size:35px;
    cursor:pointer;
}

.product-info{
    display:grid;
    grid-template-columns:auto 1fr;
    gap:10px;
}

.product-description h3{
    font-family: "Jost", sans-serif;
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0;
}

.product-description div:nth-child(2){
    font-family: "Lustria", serif;
    font-size:16px;
    font-weight:400;
}

.product-description div:nth-child(3){
    font-family: "Jost", sans-serif;
    font-size:14px;
    font-weight:300;
    letter-spacing: 0;
}

.product-img-wrapper{
    width:120px;
    height:140px;
}

.tisso-popup-content img{
    width:100%;
    height:100%;
    object-fit: cover;
}

.price{
    font-size:22px;
    margin:15px 0;
}

.view-product{
    display:inline-block;
    margin-top:20px;
    padding:12px 25px;
    background:#000;
    color:white;
    text-decoration:none;
}


@media(max-width:991px){
    .tisso-grid{
        grid-template-columns:repeat(2,1fr);
    }
}

@media(max-width:600px){
    .tisso-grid{
        grid-template-columns:1fr;
    }

    .tisso-header h2{
        font-size:32px;
    }

    .tisso-popup-content{
        grid-template-columns:1fr;
    }
}

</style>

<script>

document.addEventListener("click", function(event){

  const button = event.target.closest(".tisso-plus");

  if(button){
    const productId = button.getAttribute("data-product-id");
    const productData = document.getElementById(productId);

    if(productData){
      document.querySelector(".tisso-popup-content").innerHTML = productData.innerHTML;

      document.querySelector(".tisso-modal").classList.add("active");
    } else {
      console.log("Product data not found:", productId);
    }
  }

  if(
    event.target.classList.contains("tisso-close") 
  ){

    document.querySelector(".tisso-modal").classList.remove("active");

    document.querySelector(".tisso-popup-content").innerHTML = "";
  }
});



</script>

{%  schema %}
{
    "name": "Tisso Grid",
    "settings": [
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Tisso vison in the wild"
        },
        {
            "type": "collection",
            "id": "collection",
            "label": "Select Collection"
        }
    ],
    "presets": [
        {
            "name": "Tisso Grid"
        }
    ]
}
{% endschema %}
