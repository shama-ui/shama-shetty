<section class="tisso-vision-section">

  <div class="tisso-container">

    <!-- Header -->
    {% if section.settings.heading != blank %}
      <h2 class="tisso-title">
        {{ section.settings.heading }}
      </h2>
    {% endif %}


    <!-- Image Grid -->
    <div class="tisso-grid">

      {% for block in section.blocks %}

        <div class="tisso-card" {{ block.shopify_attributes }}>

          <div class="tisso-image-wrapper">

            {% if block.settings.image != blank %}

              {{
                block.settings.image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  width: block.settings.image.width,
                  height: block.settings.image.height,
                  alt: block.settings.product.title
              }}

            {% endif %}


            <!-- Plus Button -->
            {% if block.settings.product != blank %}

              <button
                class="tisso-hotspot"
                type="button"
                data-product="{{ block.id }}"
              >
                +
              </button>

            {% endif %}


          </div>


        </div>


      {% endfor %}

    </div>

  </div>

</section>



<!-- Product Popup -->

<div class="tisso-modal" id="tissoModal">

  <div class="tisso-modal-content">

    <button class="tisso-close">
      ×
    </button>


    <div class="tisso-product-popup">

      <img 
        id="tissoProductImage"
        src=""
        alt=""
      >


      <div class="tisso-product-info">

        <h3 id="tissoProductTitle"></h3>

        <p id="tissoProductPrice"></p>


        <form method="post" action="/cart/add">

          <input 
            type="hidden"
            name="id"
            id="tissoVariantId"
          >


          <button class="tisso-add-btn">
            Add to Cart
          </button>

        </form>


      </div>


    </div>


  </div>

</div>



<style>


.tisso-container{
  width:100%;
  max-width:1600px;
  margin:auto;
  padding:40px 20px;
}


.tisso-title{
  text-align:left;
  font-size:42px;
  margin-bottom:40px;
  font-weight:400;
}


/* GRID */

.tisso-grid{

  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:24px;

}


.tisso-image-wrapper{

 position:relative;
 overflow:hidden;

}


.tisso-image-wrapper img{

 width:100%;
 height:auto;
 display:block;

}



/* PLUS ICON */

.tisso-hotspot{

 position:absolute;
 right:15px;
 top:50%;
 transform:translateY(-50%);

 width:34px;
 height:34px;

 border-radius:50%;
 border:none;

 background:white;

 font-size:22px;
 line-height:34px;

 cursor:pointer;

 box-shadow:0 2px 10px rgba(0,0,0,.2);

 transition:.3s;

}


.tisso-hotspot:hover{

 transform:translateY(-50%) scale(1.1);

}




/* MODAL */


.tisso-modal{

 display:none;

 position:fixed;
 inset:0;

 background:rgba(0,0,0,.5);

 z-index:9999;

 align-items:center;
 justify-content:center;

}



.tisso-modal.active{

 display:flex;

}



.tisso-modal-content{

 background:#fff;

 width:90%;
 max-width:600px;

 padding:30px;

 position:relative;

}



.tisso-close{

 position:absolute;

 right:15px;
 top:10px;

 border:none;
 background:none;

 font-size:30px;

 cursor:pointer;

}



.tisso-product-popup{

 display:flex;
 gap:25px;
 align-items:center;

}


.tisso-product-popup img{

 width:200px;

}


.tisso-product-info h3{

 font-size:26px;

}


.tisso-product-info p{

 font-size:20px;

}



.tisso-add-btn{

 background:#000;
 color:#fff;

 border:none;

 padding:14px 30px;

 cursor:pointer;

}




/* TABLET */

@media(max-width:900px){

.tisso-grid{

grid-template-columns:repeat(2,1fr);

}

}




/* MOBILE */

@media(max-width:600px){

.tisso-title{

font-size:30px;

}


.tisso-grid{

grid-template-columns:repeat(2,1fr);

gap:12px;

}


.tisso-product-popup{

flex-direction:column;

}


}



</style>




<script>

document.addEventListener(
"DOMContentLoaded",
function(){


const products = {

{% for block in section.blocks %}

"{{ block.id }}":{

title:
"{{ block.settings.product.title | escape }}",

price:
"{{ block.settings.product.price | money }}",

image:
"{{ block.settings.product.featured_image | image_url: width:500 }}",

variant:
"{{ block.settings.product.selected_or_first_available_variant.id }}"

},

{% endfor %}

};



const modal =
document.getElementById("tissoModal");


const title =
document.getElementById("tissoProductTitle");


const price =
document.getElementById("tissoProductPrice");


const image =
document.getElementById("tissoProductImage");


const variant =
document.getElementById("tissoVariantId");



document.querySelectorAll(".tisso-hotspot")
.forEach(button=>{


button.addEventListener(
"click",
()=>{


let product =
products[button.dataset.product];


title.innerHTML =
product.title;


price.innerHTML =
product.price;


image.src =
product.image;


variant.value =
product.variant;



modal.classList.add("active");


}

);


});



document.querySelector(".tisso-close")
.addEventListener(
"click",
()=>{

modal.classList.remove("active");

}

);



modal.addEventListener(
"click",
(e)=>{

if(e.target===modal){

modal.classList.remove("active");

}

}

);



});

</script>



{% schema %}
{
"name":"Tisso Vision Grid",
"settings":[
{
"type":"text",
"id":"heading",
"label":"Heading",
"default":"Tisso vision in the wild"
}
],

"blocks":[

{
"type":"product_image",
"name":"Product Image",
"settings":[

{
"type":"image_picker",
"id":"image",
"label":"Image"
},

{
"type":"product",
"id":"product",
"label":"Select Product"
}

]
}

],

"presets":[
{
"name":"Tisso Vision Grid"
}
]

}
{% endschema %}